{
  "name": "filemom",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cli": "pnpm --filter @filemom/cli start"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "exifreader"]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
